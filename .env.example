# LLM Configuration
OPENAI_API_KEY=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
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here  # Alternative

# LLM Model Selection
LLM_PROVIDER=openai  # Options: openai, anthropic
LLM_MODEL=gpt-4o-mini  # or claude-3-sonnet-20240229

# Agent Configuration
MAX_RETRIES=3
RETRY_DELAY=1  # Initial delay in seconds
MAX_RETRY_DELAY=10  # Maximum delay after exponential backoff
CONCURRENT_WORKERS=3  # Number of parallel ticket processors

# Tool Configuration
TOOL_TIMEOUT=5  # Timeout for tool calls in seconds
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=5  # Failures before circuit opens

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
AUDIT_LOG_DIR=data/audit_logs
ENABLE_STRUCTURED_LOGS=true

# Confidence Thresholds
HIGH_CONFIDENCE_THRESHOLD=0.8
MEDIUM_CONFIDENCE_THRESHOLD=0.5

# Failure Handling
ENABLE_DEAD_LETTER_QUEUE=true
DLQ_PATH=data/dlq

# Security
VALIDATE_SCHEMAS=true
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=60
